<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Nao reescreve arquivos ou diretorios reais.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rotas do React Router devem cair no index.html.
  RewriteRule ^ index.html [L]
</IfModule>
